{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@planner/web",
  "sourceRoot": "apps/web/src",
  "targets": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run build",
        "cwd": "apps/web"
      }
    },
    "dev": {
      "dependsOn": [
        "^build"
      ],
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run dev",
        "cwd": "apps/web"
      }
    }
  }
}
