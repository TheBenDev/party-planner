{
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    "./character": {
      "import": "./dist/character.js",
      "require": "./dist/character.js",
      "types": "./dist/character.d.ts"
    },
    "./colony": {
      "import": "./dist/colony.js",
      "require": "./dist/colony.js",
      "types": "./dist/colony.d.ts"
    },
    "./common": {
      "import": "./dist/common.js",
      "require": "./dist/common.js",
      "types": "./dist/common.d.ts"
    },
    "./event": {
      "import": "./dist/event.js",
      "require": "./dist/event.js",
      "types": "./dist/event.d.ts"
    },
    "./i18n": {
      "import": "./dist/i18n.js",
      "require": "./dist/i18n.js",
      "types": "./dist/i18n.d.ts"
    },
    "./integration": {
      "import": "./dist/integration.js",
      "require": "./dist/integration.js",
      "types": "./dist/integration.d.ts"
    },
    "./quest": {
      "import": "./dist/quest.js",
      "require": "./dist/quest.js",
      "types": "./dist/quest.d.ts"
    },
    "./session": {
      "import": "./dist/session.js",
      "require": "./dist/session.js",
      "types": "./dist/session.d.ts"
    },
    "./user": {
      "import": "./dist/user.js",
      "require": "./dist/user.js",
      "types": "./dist/user.d.ts"
    }
  },
  "module": "src/index.ts",
  "name": "@planner/enums",
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "scripts": {
    "build": "bun run build.ts",
    "format": "biome check --linter-enabled=false --write .",
    "lint": "biome lint --write .",
    "prebuild": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
