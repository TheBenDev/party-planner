{
	"compilerOptions": {
		"baseUrl": ".",
		"forceConsistentCasingInFileNames": true,
		"importHelpers": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noFallthroughCasesInSwitch": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"outDir": "./dist",
		"paths": {
			"@/*": ["./src/*"],
			"@planner/schemas/*": ["./src/*"]
		},
		"rootDir": "./src",
		"strict": true
	},
	"extends": "../../tsconfig.base.json",
	"include": ["src/**/*.ts"]
}
