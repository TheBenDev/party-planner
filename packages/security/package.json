{
	"dependencies": {
		"@planner/schemas": "workspace:*",
		"jose": "6.1.0"
	},
	"devDependencies": {
		"@planner/enums": "workspace:*",
		"@types/bun": "catalog:",
		"typescript": "catalog:"
	},
	"exports": {
		"./auth": {
			"import": "./dist/auth.js",
