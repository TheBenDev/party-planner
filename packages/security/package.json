{
  "dependencies": {
    "@planner/schemas": "workspace:*",
    "jose": "catalog:"
  },
  "devDependencies": {
    "@planner/enums": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "require": "./dist/auth.js"
    }
  },
  "name": "@planner/security",
  "private": true,
  "scripts": {
    "build": "bun run build.ts",
    "format": "bunx biome check --linter-enabled=false --write .",
    "lint": "bunx biome lint --write .",
    "prebuild": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
